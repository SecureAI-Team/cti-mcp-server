# =============================================================
# CTI MCP Server — 环境变量配置模板
# 复制此文件为 .env 并填写 API Key
# 未填写的数据源会被自动禁用，不影响其他功能
# =============================================================

# ── API Keys ──────────────────────────────────────────────────
# VirusTotal API Key (IOC 查询)
# 免费申请: https://www.virustotal.com/gui/join-us
# 免费版: 4 次/分钟, 500 次/天
VIRUSTOTAL_API_KEY=

# AlienVault OTX API Key (威胁脉冲)
# 免费申请: https://otx.alienvault.com/api
OTX_API_KEY=

# NIST NVD API Key (可选，不填写也能使用，有 Key 速率更高)
# 免费申请: https://nvd.nist.gov/developers/request-an-api-key
NVD_API_KEY=

# ── 服务器配置 ─────────────────────────────────────────────────
MCP_SERVER_NAME=cti-mcp-server

# HTTP 传输模式端口 (默认 8080)
MCP_HTTP_PORT=8080

# HTTP 传输模式绑定地址
# 安全默认值: 127.0.0.1 (仅本机访问)
# 多 Agent 场景: 改为 0.0.0.0 并设置 MCP_AUTH_TOKEN
MCP_HTTP_HOST=127.0.0.1

# HTTP 模式 Bearer Token 认证 (留空则无认证，仅适合开发环境)
# 生成示例: python -c "import secrets; print(secrets.token_hex(32))"
MCP_AUTH_TOKEN=

# ── 速率限制 (次/分钟) ─────────────────────────────────────────
VT_RATE_LIMIT=4        # VirusTotal 免费版 4次/分钟
OTX_RATE_LIMIT=60      # OTX 默认 60次/分钟
NVD_RATE_LIMIT=5       # NVD 无 Key 时 5次/30秒

# ── 缓存配置 ──────────────────────────────────────────────────
CACHE_TTL=300          # 缓存过期时间 (秒)
CACHE_MAX_SIZE=1000    # 缓存最大条目数

# ── HTTP 配置 ──────────────────────────────────────────────────
HTTP_TIMEOUT=20        # 外部 API 请求超时 (秒)
HTTP_MAX_RETRIES=3     # 最大重试次数 (针对429/5xx)

# ── 日志配置 ──────────────────────────────────────────────────
LOG_LEVEL=INFO         # DEBUG, INFO, WARNING, ERROR
AUDIT_LOG_DIR=logs     # 审计日志目录 (相对 cti/ 目录)
